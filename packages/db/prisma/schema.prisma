generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLATFORM_ADMIN
  PLATFORM_FINANCE
  COMPANY_ADMIN
  COMPANY_AGENT
  AGENCY_AGENT
  CUSTOMER_SUPPORT
}

enum CompanyStatus {
  ONBOARDING
  ACTIVE
  INACTIVE
}

enum CustomerType {
  B2C
  B2B
  CORPORATE
  OTA
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PARTIALLY_PAID
  PAID
  REFUNDED
  FAILED
}

enum TripShift {
  SUNRISE
  FIRST_FLIGHT
  SECOND_FLIGHT
  PRIVATE_CHARTER
}

enum InventoryType {
  BALLOON_SEAT
  TEMPLE_TICKET
  BUS_TRANSFER
  SOUND_LIGHT_SHOW
  CUSTOM
}

model Company {
  id             String          @id @default(cuid())
  slug           String          @unique
  nameAr         String
  nameEn         String
  status         CompanyStatus   @default(ONBOARDING)
  email          String?
  phone          String?
  currency       String          @default("USD")
  timezone       String          @default("Africa/Cairo")
  users          User[]
  agencies       Agency[]
  priceProfiles  PriceProfile[]
  tripTemplates  TripTemplate[]
  trips          Trip[]
  bookings       Booking[]
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model User {
  id           String    @id @default(cuid())
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id])
  email        String    @unique
  fullName     String
  role         UserRole
  isActive     Boolean   @default(true)
  passwordHash String?
  bookings     Booking[] @relation("BookingCreatedBy")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId, role])
}

model Agency {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  name          String
  contactName   String?
  email         String?
  phone         String?
  customerType  CustomerType   @default(B2B)
  creditLimit   Decimal?       @db.Decimal(10, 2)
  currency      String         @default("USD")
  bookings      Booking[]
  priceProfiles PriceProfile[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
}

model PriceProfile {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  agencyId       String?
  agency         Agency?       @relation(fields: [agencyId], references: [id])
  inventoryType  InventoryType
  customerType   CustomerType
  title          String
  currency       String        @default("USD")
  adultPrice     Decimal       @db.Decimal(10, 2)
  childPrice     Decimal?      @db.Decimal(10, 2)
  infantPrice    Decimal?      @db.Decimal(10, 2)
  isDefault      Boolean       @default(false)
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId, customerType])
  @@index([agencyId])
}

model TripTemplate {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  name             String
  shift            TripShift
  defaultCapacity  Int
  defaultDurationM Int
  meetingPoint     String?
  notes            String?
  trips            Trip[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
}

model Trip {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  tripTemplateId String?
  tripTemplate   TripTemplate? @relation(fields: [tripTemplateId], references: [id])
  departureAt    DateTime
  shift          TripShift
  capacity       Int
  reservedSeats  Int           @default(0)
  baseCurrency   String        @default("USD")
  status         String        @default("scheduled")
  bookings       Booking[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId, departureAt])
}

model Booking {
  id                 String         @id @default(cuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id])
  tripId             String?
  trip               Trip?          @relation(fields: [tripId], references: [id])
  agencyId           String?
  agency             Agency?        @relation(fields: [agencyId], references: [id])
  createdByUserId    String?
  createdBy          User?          @relation("BookingCreatedBy", fields: [createdByUserId], references: [id])
  bookingReference   String         @unique
  voucherNumber      String?        @unique
  leadPassengerName  String
  leadPassengerMail  String?
  leadPassengerPhone String?
  customerType       CustomerType
  adults             Int            @default(1)
  children           Int            @default(0)
  infants            Int            @default(0)
  totalAmount        Decimal        @db.Decimal(10, 2)
  paidAmount         Decimal        @default(0) @db.Decimal(10, 2)
  currency           String         @default("USD")
  status             BookingStatus  @default(DRAFT)
  paymentStatus      PaymentStatus  @default(UNPAID)
  language           String         @default("ar")
  sourceChannel      String?
  specialRequests    String?
  tickets            TicketDocument[]
  payments           Payment[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId, status, createdAt])
  @@index([agencyId])
  @@index([tripId])
}

model TicketDocument {
  id           String   @id @default(cuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id])
  documentType String
  fileUrl      String?
  sentAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([bookingId])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id])
  provider        String
  providerRef     String?
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus
  paidAt          DateTime?
  rawResponseJson Json?
  createdAt       DateTime      @default(now())

  @@index([bookingId, status])
}

model InventoryItem {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  type            InventoryType
  title           String
  titleAr         String?
  titleEn         String?
  referenceCode   String?
  defaultCapacity Int?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([companyId, type])
}
